<Window x:Class="Bio_Athun_System.FaceEnrollmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BioAuth System" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0B0E1B"
        WindowStyle="None"
        AllowsTransparency="True">

    <Grid Background="#0B0E1B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="30,20,30,0">
            <TextBlock Text="Face Enrollment" 
                       FontSize="28" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center" 
                       Foreground="#358DE6" 
                       Margin="0,10,0,0">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#358DE6"
                                      BlurRadius="20"
                                      ShadowDepth="0"
                                      Opacity="0.6" />
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="Please place your face inside the frame and begin the examination process."
                       Foreground="#8E94B7" FontSize="14" Margin="0,5,0,0" HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Camera Preview -->
        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Width="400" Height="400" CornerRadius="200" BorderBrush="#6A5ACD" BorderThickness="3">
                <Border.Effect>
                    <DropShadowEffect Color="#6A5ACD" BlurRadius="40" ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>

                <Grid Height="400" Margin="-4,-3,-139,-3">
                    <Image x:Name="CameraPreview" 
               Stretch="UniformToFill" 
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Clip>
                            <EllipseGeometry Center="200,200" RadiusX="200" RadiusY="200" />
                        </Image.Clip>
                    </Image>
                </Grid>
            </Border>

            <TextBlock Text="Scanning..." Foreground="#6A5ACD" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,40" FontWeight="Bold"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,40">

            <Button x:Name="btnCancel" Content="Cancel" Width="120" Height="45" Background="Transparent" Foreground="#8E94B7" BorderBrush="#212745" Margin="0,0,15,0" Click="btnCancel_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button x:Name="btnStartCapture" Content="Start Capture" Click="btnStartCapture_Click" Width="139" Height="45" Background="#6A5ACD" Foreground="White" FontWeight="Bold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <Button x:Name="btnBack" Content="Back" Height="45" Background="#6A5ACD" Foreground="White" FontWeight="Bold" Margin="10,0,920,40" Grid.Row="2" Click="btnBack_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="10"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>