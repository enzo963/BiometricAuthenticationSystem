<Window x:Class="BioAthunSystem.Views.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register New User" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen" Background="#0A0E1A"
        WindowStyle="None" AllowsTransparency="True">

    <Border CornerRadius="20" Background="#FF0F1629">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FF0D1224" CornerRadius="20,0,0,20">
                <StackPanel VerticalAlignment="Center" Margin="50">
                    <Grid Margin="0,0,0,30">
                        <StackPanel>
                            <TextBlock Text="B I O M E T R I C " 
                                       FontSize="30" Foreground="#4E46B4" 
                                       FontWeight="SemiBold" FontFamily="Felix Titling" />
                            <TextBlock Text="A T H U S Y S T E M " 
                                       FontSize="40" Foreground="#FF7B7171" 
                                       FontWeight="SemiBold" FontFamily="Felix Titling" />
                        </StackPanel>
                        <Image Source="/Figam/Logo.png" Height="80" Width="80" 
                               HorizontalAlignment="Right" Stretch="Uniform">
                            <Image.Effect>
                                <DropShadowEffect Color="#4E46B4" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                            </Image.Effect>
                        </Image>
                    </Grid>

                    <Rectangle Height="3" Width="150" HorizontalAlignment="Left" Margin="0,0,0,20">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FF705DFF" Offset="0"/>
                                <GradientStop Color="#FF0CD6FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>

                    <TextBlock Text="Join our secure biometric network." 
                               Foreground="#FF2241BD" FontSize="24" FontWeight="Light" Margin="0,0,0,10" FontFamily="Bahnschrift SemiBold"/>
                    <TextBlock Text="Create your account using traditional credentials first, then you'll be able to set up facial recognition in the next step." 
                               Foreground="#FF746969" FontSize="16" TextWrapping="Wrap" LineHeight="24"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="60,0">
                <TextBlock Text="Create Account" FontSize="32" Foreground="White" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBlock Text="Enter your details to get started" Foreground="#606060" Margin="0,0,0,30"/>

                <TextBlock Text="FULL NAME" Foreground="#4E46B4" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                <Border Background="#161B30" CornerRadius="10" Margin="0,0,0,15" Padding="12,2">
                    <TextBox x:Name="txtFullName" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center" Height="35"/>
                </Border>

                <TextBlock Text="USERNAME" Foreground="#4E46B4" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                <Border Background="#161B30" CornerRadius="10" Margin="0,0,0,15" Padding="12,2">
                    <TextBox x:Name="txtUser" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14" VerticalContentAlignment="Center" Height="35"/>
                </Border>

                <TextBlock Text="PASSWORD" Foreground="#4E46B4" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                <Border Background="#161B30" CornerRadius="10" Margin="0,0,0,20" Padding="12,2">
                    <PasswordBox x:Name="txtPass" Background="Transparent" Foreground="White" BorderThickness="0" VerticalContentAlignment="Center" Height="35"/>
                </Border>

                <Button x:Name="BtnRegister" Height="50" Foreground="White" FontWeight="Bold" Margin="0,10,0,15" Click="BtnRegister_Click" Cursor="Hand">
                    <Button.Effect>
                        <DropShadowEffect Color="#6A5ACD" BlurRadius="20" ShadowDepth="0" Opacity="0.6"/>
                    </Button.Effect>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#6A5ACD" Offset="0"/>
                                        <GradientStop Color="#00BFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Content="Create Account"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Already have an account? Sign In" Background="Transparent" BorderThickness="0" Foreground="#FF5D73FF" Click="BtnBackToLogin_Click" HorizontalAlignment="Center" Cursor="Hand"/>
            </StackPanel>

            <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" Foreground="#606060" Background="Transparent" BorderThickness="0" FontSize="18" Click="BtnClose_Click"/>
        </Grid>
    </Border>
</Window>